# PostgreSQL (get free DB from neon.tech)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth secret (generate: openssl rand -base64 32)
AUTH_SECRET="your-secret-here"
NEXTAUTH_URL="https://your-app.vercel.app"

# LLM Estimation via Claude (recommended)
LLM_ENABLED=true
LLM_PROVIDER=anthropic
LLM_API_KEY=sk-ant-your-key-here
LLM_MODEL=claude-haiku-4-5-20251001

# Or OpenAI:
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-your-openai-key
# LLM_MODEL=gpt-4o-mini

# --- Partner / anniversary personalization (optional) ---
# If SWEETHEART_USERNAME is unset, no special partner UI fires.
SWEETHEART_USERNAME=
# Name shown in love-message UI (signature + "X Loves you")
PARTNER_NAME=
# Wedding date in YYYY-MM-DD — drives anniversary countdown + takeover
ANNIVERSARY_DATE=

# --- Seed (only needed when running `prisma db seed`) ---
SEED_PASSWORD=
SEED_PRIMARY_USERNAME=
SEED_PARTNER_USERNAME=
