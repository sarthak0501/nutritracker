DATABASE_URL="file:./dev.db"

# Enable/disable LLM-powered estimation endpoints.
LLM_ENABLED="false"

# OpenAI-compatible chat completions endpoint base URL.
# Examples:
# - OpenAI: https://api.openai.com/v1
# - Local gateway: http://localhost:11434/v1 (if you run an OpenAI-compatible proxy)
LLM_BASE_URL="https://api.openai.com/v1"

# API key for your provider (or leave empty for local/no-auth providers).
LLM_API_KEY=""

# Model name (provider-specific). Example for OpenAI: gpt-4o-mini
LLM_MODEL="gpt-4o-mini"

