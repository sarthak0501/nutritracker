generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
  CUSTOM
}

enum AmountUnit {
  GRAM
  SERVING
}

enum FoodSource {
  MANUAL
  OPEN_FOOD_FACTS
  LLM
}

enum BuddyStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum ReactionType {
  THUMBS_UP
  THUMBS_DOWN
  FIRE
  MUSCLE
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile      Profile?
  logEntries   LogEntry[]
  workoutEntries WorkoutEntry[]
  weightEntries  WeightEntry[]
  waterEntries   WaterEntry[]

  buddyRequestsSent     BuddyRelationship[] @relation("Requester")
  buddyRequestsReceived BuddyRelationship[] @relation("Addressee")

  reactionsGiven Reaction[]

  @@index([username])
}

model Profile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  kcalTarget    Float    @default(2000)
  proteinTarget Float    @default(120)
  carbsTarget   Float    @default(250)
  fatTarget     Float    @default(70)
  fiberTarget   Float?   @default(30)

  heightCm        Float?
  weightKg        Float?
  age             Int?
  gender          String?
  equipmentPreset String?
  equipment       String[] @default([])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Food {
  id              String     @id @default(cuid())
  name            String
  brand           String?
  source          FoodSource @default(MANUAL)

  barcode         String?    @unique
  offUrl          String?
  offLastFetchedAt DateTime?

  kcalPer100g     Float
  proteinPer100g  Float
  carbsPer100g    Float
  fatPer100g      Float
  fiberPer100g    Float?
  sodiumMgPer100g Float?

  servingName     String?
  servingGrams    Float?

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  logEntries      LogEntry[]

  @@index([name])
}

model LogEntry {
  id             String     @id @default(cuid())

  userId         String
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  date           String
  mealType       MealType
  mealName       String?

  amount         Float
  unit           AmountUnit @default(GRAM)

  sourceText     String?
  isEstimated    Boolean    @default(false)
  estimationMeta Json?

  foodId         String
  food           Food       @relation(fields: [foodId], references: [id], onDelete: Cascade)

  reactions      Reaction[]

  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([date])
  @@index([userId, date])
  @@index([mealType, date])
}

model BuddyRelationship {
  id          String      @id @default(cuid())
  requesterId String
  addresseeId String
  status      BuddyStatus @default(PENDING)

  requester   User        @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee   User        @relation("Addressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@index([requesterId, status])
}

model Reaction {
  id         String       @id @default(cuid())
  logEntryId String
  userId     String
  type       ReactionType

  logEntry   LogEntry     @relation(fields: [logEntryId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt  DateTime     @default(now())

  @@unique([logEntryId, userId, type])
  @@index([logEntryId])
  @@index([userId])
}

model WeightEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  weightKg  Float
  date      String

  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@index([userId, date])
}

model WaterEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  date      String
  glasses   Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
}

model WorkoutEntry {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  date            String
  exerciseName    String
  muscleGroup     String?
  durationMinutes Float?
  sets            Int?
  reps            Int?
  weightKg        Float?

  caloriesBurned  Float
  isEstimated     Boolean  @default(false)
  sourceText      String?
  estimationMeta  Json?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([date])
  @@index([userId, date])
}
